<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="SyncClipboard.WinUI3.Views.OpenSourceNoticePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="using:CommunityToolkit.WinUI.Controls"
      xmlns:m="using:SyncClipboard.Core.Models"
      xmlns:i18n="using:SyncClipboard.Core.I18n"
      MinWidth="550"
      BorderBrush="Transparent"
      mc:Ignorable="d">
    <StackPanel Spacing="12">
        <StackPanel Spacing="4">
            <TextBlock Text="{x:Bind i18n:Strings.OssNoticeTitle}" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind i18n:Strings.OssNoticeSubtitle}"
                       Opacity="0.8"
                       TextWrapping="WrapWholeWords" />
        </StackPanel>

        <ui:SettingsExpander Header="{x:Bind i18n:Strings.OssNoticeTitle}" IsExpanded="True">
            <ui:SettingsExpander.HeaderIcon>
                <FontIcon Glyph="&#xE946;" />
            </ui:SettingsExpander.HeaderIcon>
            <ui:SettingsExpander.Items>
                <ui:SettingsCard Description="{x:Bind i18n:Strings.OssFreeStatement}" />
                <ui:SettingsCard Description="{x:Bind i18n:Strings.OssAntiScamStatement}" />
            </ui:SettingsExpander.Items>
        </ui:SettingsExpander>

        <ui:SettingsExpander Header="{x:Bind i18n:Strings.OpenSourceNotice}" IsExpanded="True">
            <ui:SettingsExpander.HeaderIcon>
                <FontIcon Glyph="&#xE774;" />
            </ui:SettingsExpander.HeaderIcon>
            <ui:SettingsExpander.Items>
                <ui:SettingsCard Header="{x:Bind i18n:Strings.ForkRepository}">
                    <HyperlinkButton Content="{x:Bind _viewModel.ForkRepositoryUrl}" Click="ForkButton_Click" />
                </ui:SettingsCard>
                <ui:SettingsCard Header="{x:Bind i18n:Strings.UpstreamRepository}">
                    <HyperlinkButton Content="{x:Bind _viewModel.UpstreamRepositoryUrl}" Click="UpstreamButton_Click" />
                </ui:SettingsCard>
                <ui:SettingsCard Header="{x:Bind i18n:Strings.License}"
                                 Description="{x:Bind _viewModel.ProjectCopyright}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock VerticalAlignment="Center" Text="{x:Bind _viewModel.ProjectLicenseName}" />
                        <Button Content="{x:Bind i18n:Strings.OssViewFullLicense}" Click="ViewLicense_Click" />
                    </StackPanel>
                </ui:SettingsCard>
            </ui:SettingsExpander.Items>
        </ui:SettingsExpander>

        <ui:SettingsExpander Header="{x:Bind i18n:Strings.OssDependencies}"
                             IsExpanded="True"
                             ItemsSource="{x:Bind _viewModel.Dependencies}">
            <ui:SettingsExpander.HeaderIcon>
                <FontIcon Glyph="&#xE1D3;" />
            </ui:SettingsExpander.HeaderIcon>
            <ui:SettingsExpander.ItemTemplate>
                <DataTemplate x:DataType="m:OpenSourceSoftware">
                    <ui:SettingsCard Header="{x:Bind Name}"
                                     Description="{x:Bind Description}"
                                     IsClickEnabled="True"
                                     Click="DependencyLicense_Click"
                                     Tag="{x:Bind}">
                        <ui:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8A5;" />
                        </ui:SettingsCard.HeaderIcon>
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind Author}" Opacity="0.8" />
                            <TextBlock Text="{x:Bind LicenseName}" Opacity="0.8" />
                            <HyperlinkButton Content="{x:Bind HomePage}"
                                             Tag="{x:Bind HomePage}"
                                             Click="DependencyHome_Click"
                                             Padding="0" />
                        </StackPanel>
                    </ui:SettingsCard>
                </DataTemplate>
            </ui:SettingsExpander.ItemTemplate>
        </ui:SettingsExpander>

        <Button x:Name="_PrimaryAction"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}"
                Click="PrimaryAction_Click"
                Content="{x:Bind i18n:Strings.OssIUnderstandContinue}" />
    </StackPanel>
</Page>
